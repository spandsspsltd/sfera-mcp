# SFERA MCP Server — Environment Variables
# Copy to .env for local development. Set in Railway dashboard for production.
# NEVER commit actual values to Git.

# Supabase project URL
SUPABASE_URL=https://iclairkjhebamzjtzncq.supabase.co

# Supabase service_role key — found in Supabase project Settings > API
# WARNING: This key bypasses ALL Row Level Security. Store only as env var.
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Shared secret between Claude custom connector and this server
# Generate with: openssl rand -hex 32
MCP_API_KEY=your_32_char_random_secret_here
